APP_VERSION=0.1.0
CORS_ORIGINS=http://localhost:8080
MAX_UPLOAD_BYTES=104857600
SQLITE_PATH=/app/backend_data/analyses.db
STORAGE_BASE_DIR=/app/backend_data
TASK_WORKERS=1
TASK_TTL_SECONDS=604800
CLEANUP_INTERVAL_SECONDS=600
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
CHAT_ANALYZER_FALLBACK_JSON_MAX_BYTES=52428800
CHAT_ANALYZER_NLP_WORKERS=1
VITE_API_BASE_URL=/api
API_IMAGE=ghcr.io/iwkms99/chat-analyzer-api:latest
WEB_IMAGE=ghcr.io/iwkms99/chat-analyzer-web:latest
