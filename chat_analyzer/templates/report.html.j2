<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Chat Analyzer Report</title>
  <style>
    body { font-family: "Segoe UI", Arial, sans-serif; margin: 24px; color: #16212f; background: linear-gradient(120deg,#f7fbff,#eef5ff); }
    h1,h2,h3 { margin-bottom: 8px; }
    .grid { display: grid; grid-template-columns: repeat(auto-fit,minmax(260px,1fr)); gap: 12px; margin: 16px 0; }
    .card { background: #fff; border: 1px solid #d9e5f7; border-radius: 10px; padding: 12px; }
    .chart { margin: 20px 0; background: #fff; border-radius: 12px; padding: 12px; border: 1px solid #d9e5f7; }
    table { border-collapse: collapse; width: 100%; background: #fff; }
    td,th { border: 1px solid #dbe3ee; padding: 8px; text-align: left; }
    .small { color: #506079; font-size: 13px; }
  </style>
</head>
<body>
  <h1>Chat Analyzer Report</h1>
  <p class="small">Период: {{ summary.start }} - {{ summary.end }}</p>

  <div class="grid">
    <div class="card"><strong>Total messages</strong><div>{{ summary.total_messages }}</div></div>
    <div class="card"><strong>Participants</strong><div>{{ summary.participants }}</div></div>
    <div class="card"><strong>Timezone</strong><div>{{ summary.timezone }}</div></div>
  </div>

  <h2>Top Insights</h2>
  <ol>
  {% for insight in insights %}
    <li><strong>{{ insight.title }}</strong>: {{ insight.value }}<br/><span class="small">{{ insight.evidence }}</span></li>
  {% endfor %}
  </ol>

  <h2>Module Metrics</h2>
  {% for module_name, payload in modules.items() %}
    {% if payload.metrics %}
      <h3>{{ module_name }}</h3>
      <table>
        <thead><tr><th>Metric</th><th>Value</th></tr></thead>
        <tbody>
        {% for key, value in payload.metrics.items() %}
          <tr><td>{{ key }}</td><td>{{ value }}</td></tr>
        {% endfor %}
        </tbody>
      </table>
    {% endif %}
  {% endfor %}

  <h2>Charts</h2>
  {% for chart in charts %}
    <div class="chart">
      <h3>{{ chart.name }}</h3>
      {% if chart.html_embed %}
        {{ chart.html_embed | safe }}
      {% else %}
        <p class="small">Interactive chart unavailable</p>
      {% endif %}
      {% if chart.png_path %}<p class="small">PNG: {{ chart.png_path }}</p>{% endif %}
    </div>
  {% endfor %}

  {% if extra_artifacts %}
  <h2>Extra Artifacts</h2>
  <ul>
    {% for name, path in extra_artifacts.items() %}
      <li>{{ name }}: {{ path }}</li>
    {% endfor %}
  </ul>
  {% endif %}
</body>
</html>
